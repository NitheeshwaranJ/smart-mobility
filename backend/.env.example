# Copy to .env and fill in real values
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/smart_mobility
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MIN=1440
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional — enables AI Assistant. Works with any OpenAI-compatible endpoint
# (OpenAI, Lovable AI Gateway, OpenRouter, Groq, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
